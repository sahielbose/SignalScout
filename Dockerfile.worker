# Signal Scout worker (pg-boss). Runs DB migrations on boot, then the scheduler.
# Build: docker build -f Dockerfile.worker -t signalscout-worker .
FROM node:22-slim AS base
RUN corepack enable
WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .

ENV NODE_ENV=production
# The worker applies migrations on boot (it has tsx + full deps), then schedules.
CMD ["sh", "-c", "pnpm db:migrate && pnpm worker"]
