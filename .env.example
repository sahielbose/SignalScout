# =====================================================================
# Signal Scout — environment template.
# Copy to `.env` and fill in. NEVER commit `.env`. No secret goes in code.
# =====================================================================

# --- core ---
# Local dev DB runs on 5434 (see docker-compose.yml) to avoid colliding
# with other local Postgres instances.
DATABASE_URL=postgres://signalscout:signalscout@localhost:5434/signalscout
AUTH_SECRET=                              # `openssl rand -base64 32`
AUTH_URL=http://localhost:3000            # NextAuth v5 base url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- auth providers ---
AUTH_GITHUB_ID=                           # GitHub OAuth app client id
AUTH_GITHUB_SECRET=                       # GitHub OAuth app client secret
# Email magic-link uses SMTP_URL below (optional in dev — links are logged)

# --- data sources (free / public) ---
SEC_USER_AGENT="Signal Scout dev@example.com"  # REQUIRED by SEC EDGAR
GITHUB_TOKEN=                             # free PAT for Octokit (higher rate limit)

# --- LLM provider (pluggable; pick one) ---
LLM_PROVIDER=anthropic                    # anthropic | ollama
ANTHROPIC_API_KEY=                        # if anthropic
LLM_CLASSIFY_MODEL=claude-haiku-4-5-20251001   # cheap model for classification
LLM_RESEARCH_MODEL=claude-sonnet-4-6      # stronger model for dossiers
LLM_EMBED_MODEL=                          # optional remote embedder; falls back to local hash embed if blank
OLLAMA_BASE_URL=http://localhost:11434    # if LLM_PROVIDER=ollama
OLLAMA_CLASSIFY_MODEL=llama3.1
OLLAMA_RESEARCH_MODEL=llama3.1

# --- search for deep research (pluggable) ---
SEARCH_PROVIDER=tavily                    # tavily | exa | searxng (searxng = open self-host)
TAVILY_API_KEY=
EXA_API_KEY=
SEARXNG_URL=http://localhost:8888

# --- email / notify (open via SMTP) ---
SMTP_URL=                                 # smtp://user:pass@host:587 (Nodemailer). Blank in dev = links logged.
EMAIL_FROM="Signal Scout <noreply@example.com>"
SLACK_WEBHOOK_URL=                        # optional (Stage 2 notifications)

# --- cost / abuse control (Phase 10) ---
DAILY_CLASSIFY_QUOTA=500                  # per-org classifier calls/day
DAILY_RESEARCH_QUOTA=25                   # per-org dossiers/day
GLOBAL_BUDGET_USD=10                      # global daily spend kill-switch (0 = unlimited)
GLOBAL_KILL_SWITCH=false                  # set true to halt all LLM/search spend

# --- paid enrichment (OPTIONAL, OFF by default, user-supplied credits) ---
ENABLE_PAID_ENRICHMENT=false
APOLLO_API_KEY=
PDL_API_KEY=

# --- observability (optional) ---
SENTRY_DSN=
LOG_LEVEL=info

# --- CRM push (Stage-2, gated, OFF by default; no key = safe no-op) ---
ENABLE_CRM=false
CRM_PROVIDER=none                     # none | hubspot | salesforce
HUBSPOT_API_KEY=
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# --- incorporation feed (OFF by default; needs a paid registry) ---
ENABLE_INCORPORATION=false
OPENCORPORATES_API_KEY=

# --- scheduled flat-file delivery (email works via log-fallback; S3 needs keys) ---
SCHEDULED_CSV_DELIVERY=false
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
